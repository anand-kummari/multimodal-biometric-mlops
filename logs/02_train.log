  cache_dir: ${storage.base_path}/cache
  checkpoint_dir: ${hydra:runtime.cwd}/checkpoints
project:
  name: multimodal-biometric-mlops
  seed: 42
  device: auto
logging:
  level: INFO
  format: '%(asctime)s | %(levelname)-8s | %(name)s | %(message)s'
  file: null

